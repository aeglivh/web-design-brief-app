{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/generate.js": { "maxDuration": 60 },
    "api/quote.js": { "maxDuration": 60 },
    "api/extract.js": { "maxDuration": 15 },
    "api/send-email.js": { "maxDuration": 10 },
    "api/designer.js": { "maxDuration": 10 },
    "api/rates.js": { "maxDuration": 10 },
    "api/briefs.js": { "maxDuration": 10 },
    "api/contract.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "toolbar": {
    "enabled": false
  }
}
